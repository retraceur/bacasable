{
	"name": "@retraceur/bacasable",
	"version": "0.9.0",
	"description": "A Node.js tool to instantly build your local Retraceur development environment",
	"keywords": [
		"retraceur",
		"cli",
		"development",
		"local",
		"webassembly",
		"php"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/retraceur/bacasable.git"
	},
	"bugs": {
		"url": "https://github.com/retraceur/bacasable/issues"
	},
	"bin": {
		"bacasable": "./build/main.js"
	},
	"main": "./build/main.js",
	"scripts": {
		"build": "node esbuild.mjs",
		"dev": "tsc --watch",
		"test": "vitest",
		"lint": "eslint src",
		"format": "prettier --write src"
	},
	"dependencies": {
		"@php-wasm/node": "latest",
		"@php-wasm/universal": "latest",
		"@webcontainer/env": "^1.1.1",
		"@wp-playground/blueprints": "latest",
		"commander": "^11.0.0",
		"compressible": "^2.0.18",
		"compression": "^1.8.1",
		"express": "^4.18.0",
		"follow-redirects": "^1.15.11",
		"fs-extra": "^11.3.3",
		"hpagent": "^1.2.0",
		"unzipper": "^0.12.3"
	},
	"devDependencies": {
		"@types/compression": "^1.8.1",
		"@types/express": "^4.17.0",
		"@types/follow-redirects": "^1.14.4",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "^6.0.0",
		"@typescript-eslint/parser": "^6.0.0",
		"eslint": "^8.0.0",
		"prettier": "^3.0.0",
		"typescript": "^5.0.0",
		"vitest": "^1.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"homepage": "https://retraceur.github.io/tools/bacasable/",
	"author": "Communauté Retraceur",
	"contributors": [
		{
			"name": "imath",
			"url": "https://github.com/imath"
		}
	],
	"license": "GPL-2.0-or-later",
	"type": "module",
	"files": [
		"build",
		"node_modules",
		"package.json"
	]
}
